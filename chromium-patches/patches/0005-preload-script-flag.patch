From: FlareSolverr Stealth Migration
Subject: [PATCH 5/6] Add --preload-script flag for document-start JS injection

Chrome DevTools Protocol Page.addScriptToEvaluateOnNewDocument is
fragile: it requires an explicit CDP call, ordering matters, and the
injected script is visible to fingerprinters who inspect getter
descriptors.

This patch adds a --preload-script=<path> command-line switch. The
browser reads the script once at startup and registers it via
WebContentsImpl::AddScriptToEvaluateOnNewDocument for every new
WebContents instance, exactly matching the CDP mechanism but without
any round-trip. The script runs at document_start in every new document
context, before any page scripts.

--- a/content/browser/web_contents/web_contents_impl.cc
+++ b/content/browser/web_contents/web_contents_impl.cc
@@ -25,6 +25,8 @@
 #include "base/check.h"
+#include "base/command_line.h"
+#include "base/files/file_util.h"
 #include "base/check_op.h"
 #include "base/containers/contains.h"

@@ -600,6 +602,24 @@ void WebContentsImpl::Init(const WebContents::CreateParams& params,
                            blink::FramePolicy frame_policy) {
   // ... existing Init body ...

+  // --preload-script: register a JS file to run at document_start in every
+  // new document context for this WebContents. Uses the same mechanism as
+  // Page.addScriptToEvaluateOnNewDocument but without a CDP round-trip.
+  // The static ensures the file is read at most once per process lifetime.
+  {
+    static std::string preload_script_content;
+    static bool preload_script_loaded = false;
+    if (!preload_script_loaded) {
+      preload_script_loaded = true;
+      base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+      if (cmd->HasSwitch("preload-script")) {
+        base::ReadFileToString(
+            cmd->GetSwitchValuePath("preload-script"), &preload_script_content);
+      }
+    }
+    if (!preload_script_content.empty()) {
+      AddScriptToEvaluateOnNewDocument(preload_script_content, std::nullopt);
+    }
+  }
 }
