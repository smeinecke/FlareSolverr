From: FlareSolverr Stealth Migration
Subject: [PATCH 3/6] Make navigator.webdriver always return undefined

ChromeDriver sets navigator.webdriver to true. The JS stealth layer
overrides this with a prototype getter, but that getter itself is
detectable via Object.getOwnPropertyDescriptor().

This patch changes the IDL attribute from boolean to nullable boolean
and returns std::nullopt unconditionally, so JS sees undefined
natively — no override needed and no detectable getter.

--- a/third_party/blink/renderer/modules/navigatorcontrolled/navigator_controlled.idl
+++ b/third_party/blink/renderer/modules/navigatorcontrolled/navigator_controlled.idl
@@ -8,5 +8,5 @@
     NavigatorControlled
 ] {
-    readonly attribute boolean webdriver;
+    readonly attribute boolean? webdriver;
 };
--- a/third_party/blink/renderer/modules/navigatorcontrolled/navigator_controlled.h
+++ b/third_party/blink/renderer/modules/navigatorcontrolled/navigator_controlled.h
@@ -10,5 +10,6 @@
 #ifndef THIRD_PARTY_BLINK_RENDERER_MODULES_NAVIGATORCONTROLLED_NAVIGATOR_CONTROLLED_H_
 #define THIRD_PARTY_BLINK_RENDERER_MODULES_NAVIGATORCONTROLLED_NAVIGATOR_CONTROLLED_H_

+#include <optional>
 #include "third_party/blink/renderer/core/frame/navigator.h"

@@ -18,7 +19,7 @@ class NavigatorControlled final
     : public Supplement<Navigator> {
  public:
   static const char kSupplementName[];
   static NavigatorControlled& From(Navigator&);
-  bool webdriver() const;
+  std::optional<bool> webdriver() const;

   void Trace(Visitor*) const override;
 };
--- a/third_party/blink/renderer/modules/navigatorcontrolled/navigator_controlled.cc
+++ b/third_party/blink/renderer/modules/navigatorcontrolled/navigator_controlled.cc
@@ -10,6 +10,6 @@ namespace blink {
-bool NavigatorControlled::webdriver() const {
-  return true;
+std::optional<bool> NavigatorControlled::webdriver() const {
+  return std::nullopt;
 }
 }  // namespace blink
