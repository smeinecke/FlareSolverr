From: FlareSolverr Stealth Migration
Subject: [PATCH 1/6] Add --enable-trusted-synthetic-events flag for CDP events

When Chrome DevTools Protocol (CDP) dispatches synthetic events,
Event::isTrusted() returns false, which is a detectable bot indicator.
This patch adds a command-line switch that forces all CDP-generated
events to report isTrusted=true.

--- a/third_party/blink/renderer/core/dom/events/event.cc
+++ b/third_party/blink/renderer/core/dom/events/event.cc
@@ -10,6 +10,7 @@
 #include "base/check.h"
+#include "base/command_line.h"
 #include "third_party/blink/renderer/core/dom/abstract_range.h"
 #include "third_party/blink/renderer/core/dom/document.h"
@@ -302,6 +303,10 @@ void Event::SetTrusted(bool trusted) {
 }
 
 bool Event::isTrusted() const {
+  if (base::CommandLine::ForCurrentProcess()->HasSwitch(
+          "enable-trusted-synthetic-events")) {
+    return true;
+  }
   return trusted_;
 }
 
